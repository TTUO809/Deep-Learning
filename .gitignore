# =================================================================
# ML/DL Model Weights and Large Data Files
# =================================================================
# Exclude model weights and training checkpoints
*.pth
*.pt

# Exclude training logs and data exports
*.log
*.csv

# Exclude media files by default
# (Specific project assets are re-included in the sections below)
*.png
*.mp4

# Global exclusion for generic ignore and wandb folders
Ignore/
wandb/

# =================================================================
# Lab-Specific Rules
# =================================================================

