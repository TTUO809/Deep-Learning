{
  "latex-workshop.latex.tools": [
    {
      "name": "pdflatex",
      "command": "/usr/bin/pdflatex",
      "args": [
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "-recorder",
        "%DOC%"
      ]
    },
    {
      "name": "bibtex",
      "command": "/usr/bin/bibtex",
      "args": ["%DOCFILE%"]
    }
  ],
  "latex-workshop.latex.recipes": [
    {
      "name": "pdflatex",
      "tools": ["pdflatex"]
    },
    {
      "name": "pdflatex × 2",
      "tools": ["pdflatex", "pdflatex"]
    }
  ],
  "latex-workshop.view.pdf.viewer": "tab"
}
